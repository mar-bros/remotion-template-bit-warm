  "subtitles": [
    {
      "en": "My Father's Silence",
      "zh": "父亲的背影",
      "startSec": 0.0,
      "id": 0.0,
      "endSec": 0.96,
      "duration": 0.0
    },
    {
      "en": "He never speaks of love.",
      "zh": "他从不谈论爱",
      "startSec": 1.52,
      "id": 1.52,
      "endSec": 2.8,
      "duration": 0.3999999999999999
    },
    {
      "en": "Yet he traded his prime for the simple needs of home.",
      "zh": "却把最好的年华都换成了柴米油盐",
      "startSec": 3.12,
      "id": 3.12,
      "endSec": 5.68,
      "duration": 0.3199999999999994
    },
    {
      "en": "His back was once the entirety of my sky.",
      "zh": "他的脊背曾是我的整片天空",
      "startSec": 6.32,
      "id": 6.32,
      "endSec": 8.8,
      "duration": 0.2400000000000002
    },
    {
      "en": "Now it’s just a curve weathered by the years.",
      "zh": "如今却缩成了一道被岁月压弯的弧线。",
      "startSec": 9.52,
      "id": 9.52,
      "endSec": 12.32,
      "duration": 0.3200000000000003
    },
    {
      "en": "May we grow faster than the pace of his aging.",
      "zh": "我们长大的速度，请一定要快过他老去的速度",
      "startSec": 13.04,
      "id": 13.04,
      "endSec": 16.72,
      "duration": 0.3200000000000003
    }
  ],
